{
  "name": "@tencent/verify-article-structure",
  "version": "0.1.4",
  "private": false,
  "description": "Article structure & style checker CLI — full-rule detection via a real Puppeteer browser, plus redundant-nesting dedupe cleanup.",
  "type": "module",
  "license": "MIT",
  "main": "dist/src/cli.js",
  "bin": {
    "verify-article-structure": "dist/src/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://mirrors.tencent.com/npm/"
  },
  "scripts": {
    "check": "tsx src/index.ts",
    "probe": "tsx src/probe.ts",
    "dedupe": "tsx src/clean.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test:behavior": "vitest run tests/behavior/regression.test.ts",
    "test:e2e": "vitest run tests/cli.test.ts",
    "test": "vitest run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "esbuild": "^0.21.5",
    "jsdom": "^24.1.3",
    "mp-darkmode": "1.2.3-alpha.1",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
